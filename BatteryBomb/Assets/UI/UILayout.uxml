<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label text="Score: 0" name="ScoreLabel" selectable="false" focusable="false" style="top: 20px; align-self: center; color: rgb(255, 255, 255); -unity-font-style: bold; font-size: 30px; border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-left-color: rgb(255, 255, 255); border-right-color: rgb(255, 255, 255); border-top-color: rgb(255, 255, 255); border-bottom-color: rgb(255, 255, 255); border-top-left-radius: 4px; border-top-right-radius: 4px; border-bottom-right-radius: 4px; border-bottom-left-radius: 4px; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px;"/>
    <ui:Button text="Restart" name="RestartButton" style="padding-left: 30px; padding-right: 30px; border-top-left-radius: 4px; border-bottom-left-radius: 4px; border-top-right-radius: 4px; border-bottom-right-radius: 4px; align-self: center; position: absolute; top: 50%; -unity-font-style: bold-and-italic; color: rgb(82, 156, 67); font-size: 40px; padding-top: 30px; padding-bottom: 30px;"/>
</ui:UXML>
